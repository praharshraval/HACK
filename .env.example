# Oasis — Environment Configuration
# Copy this file to .env and fill in your values

# ── Supabase (Required for production auth) ──
# Create a free project at https://supabase.com
# Then go to Project Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── GitHub OAuth (configured inside Supabase) ──
# 1. Create a GitHub OAuth App: https://github.com/settings/developers
# 2. Set Homepage URL to your deployed URL (e.g., https://oasis.vercel.app)
# 3. Set Authorization callback URL to: https://<your-supabase-project>.supabase.co/auth/v1/callback
# 4. Go to Supabase Dashboard → Authentication → Providers → GitHub
# 5. Paste your Client ID and Client Secret there
# (No env vars needed here — Supabase handles it server-side)
